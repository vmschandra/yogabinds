{
  "redirects": [
    { "source": "/", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/index.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/journey.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/contact.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/payment.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/payment-success.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/my-bookings.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/faqs.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/terms.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/privacy-policy.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/refund-policy.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/landing.html", "destination": "/maintenance.html", "statusCode": 302 },
    { "source": "/admin.html", "destination": "/maintenance.html", "statusCode": 302 }
  ],
  "functions": {
    "api/create-checkout-session.js": {
      "maxDuration": 10
    },
    "api/refund-booking.js": {
      "maxDuration": 15
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/download-invoice.js": {
      "maxDuration": 10
    },
    "api/admin-data.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-site" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.jsdelivr.net https://js.stripe.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://api.stripe.com https://*.google-analytics.com https://*.analytics.google.com; frame-src https://js.stripe.com https://*.firebaseapp.com https://accounts.google.com;" }
      ]
    }
  ]
}
